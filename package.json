{
  "name": "@flyingrobots/graft",
  "version": "0.2.0",
  "description": "Context governor for coding agents — MCP server with policy-enforced reads, structural outlines, and session tracking",
  "type": "module",
  "bin": {
    "graft": "./bin/graft.js",
    "git-graft": "./bin/graft.js"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "llm",
    "agent",
    "context",
    "mcp",
    "tree-sitter",
    "code-navigation",
    "structural-reads"
  ],
  "author": "James Ross <james@flyingrobots.dev>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingrobots/graft.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "picomatch": "^4.0.4",
    "tree-sitter-wasms": "0.1.13",
    "tsx": "^4.21.0",
    "web-tree-sitter": "^0.20.8",
    "zod": "4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
